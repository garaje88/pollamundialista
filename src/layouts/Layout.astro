---
// src/layouts/Layout.astro
export interface Props {
  title?: string;
  description?: string;
  activePage?: string;
}
const {
  title = 'Polla Mundial 2026',
  description = 'Predice los resultados del FIFA Mundial 2026 y compite con tus compañeros de SaludTools',
  activePage = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title} | Polla Mundial 2026</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-inner container">

      <!-- Logo: SaludTools × Mundial 2026 -->
      <a href="/" class="navbar-brand" style="text-decoration:none;">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="11" fill="#E53040"/>
          <path d="M11 5.5v11M5.5 11h11" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
        <span style="font-family:'Inter',sans-serif;font-weight:700;font-size:0.95rem;color:#1A2B52;letter-spacing:-0.01em;">saludtools</span>
        <span style="color:rgba(26,43,82,0.25);font-size:0.9rem;margin:0 0.2rem;">×</span>
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.15rem;color:var(--color-primary);letter-spacing:-0.01em;">
          Mundial<span style="color:var(--color-gold);">2026</span>
        </span>
      </a>

      <!-- Nav links -->
      <div class="navbar-nav">
        <a href="/"                 class={`nav-link ${activePage === 'inicio'       ? 'active' : ''}`}>Inicio</a>
        <a href="/partidos"         class={`nav-link ${activePage === 'partidos'     ? 'active' : ''}`}>Partidos</a>
        <a href="/mis-predicciones" class={`nav-link ${activePage === 'predicciones' ? 'active' : ''}`}>Mis Picks</a>
        <a href="/clasificacion"    class={`nav-link ${activePage === 'clasificacion'? 'active' : ''}`}>Tabla</a>
        <a href="/grupos"           class={`nav-link ${activePage === 'grupos'       ? 'active' : ''}`}>Grupos</a>
        <a href="/admin" class="nav-link" id="nav-admin" style="display:none;">Admin</a>
      </div>

      <!-- Auth area -->
      <div style="display:flex;align-items:center;gap:0.75rem;" id="navbar-auth">
        <a href="/login" class="btn btn-primary btn-sm" id="btn-login">
          Iniciar sesión
        </a>
      </div>

    </div>
  </nav>

  <!-- Page content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="grid-3" style="gap:2rem;">
        <div>
          <!-- Footer logo -->
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <svg width="18" height="18" viewBox="0 0 22 22" fill="none" aria-hidden="true">
              <circle cx="11" cy="11" r="11" fill="#E53040"/>
              <path d="M11 5.5v11M5.5 11h11" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
            <span style="font-family:'Inter',sans-serif;font-weight:700;font-size:0.85rem;color:rgba(255,255,255,0.9);">saludtools</span>
            <span style="color:rgba(255,255,255,0.25);font-size:0.8rem;">×</span>
            <span style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1rem;color:#fff;">
              Mundial<span style="color:var(--color-gold);">2026</span>
            </span>
          </div>
          <p style="font-size:0.83rem;color:rgba(255,255,255,0.5);max-width:220px;line-height:1.55;">
            La polla del Mundial para el equipo de SaludTools. Canada · México · USA.
          </p>
        </div>

        <div>
          <p style="font-weight:600;font-size:0.75rem;color:rgba(255,255,255,0.4);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.75rem;">
            Navegación
          </p>
          <div style="display:flex;flex-direction:column;gap:0.45rem;">
            {[
              ['/', 'Inicio'],
              ['/partidos', 'Partidos'],
              ['/mis-predicciones', 'Mis Predicciones'],
              ['/clasificacion', 'Clasificación'],
              ['/grupos', 'Grupos'],
            ].map(([href, label]) => (
              <a href={href} style="font-size:0.83rem;color:rgba(255,255,255,0.55);transition:color 0.15s;"
                 onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">{label}</a>
            ))}
          </div>
        </div>

        <div>
          <p style="font-weight:600;font-size:0.75rem;color:rgba(255,255,255,0.4);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.75rem;">
            Puntuación
          </p>
          <div style="display:flex;flex-direction:column;gap:0.6rem;">
            <div style="display:flex;align-items:center;gap:0.6rem;">
              <span style="background:var(--color-gold);color:#1A2B52;padding:0.15rem 0.55rem;border-radius:4px;font-weight:700;font-size:0.8rem;font-family:'Barlow Condensed',sans-serif;">5 pts</span>
              <span style="font-size:0.83rem;color:rgba(255,255,255,0.55);">Resultado exacto</span>
            </div>
            <div style="display:flex;align-items:center;gap:0.6rem;">
              <span style="background:var(--color-green);color:#fff;padding:0.15rem 0.55rem;border-radius:4px;font-weight:700;font-size:0.8rem;font-family:'Barlow Condensed',sans-serif;">2 pts</span>
              <span style="font-size:0.83rem;color:rgba(255,255,255,0.55);">Ganador / empate</span>
            </div>
            <div style="display:flex;align-items:center;gap:0.6rem;">
              <span style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);padding:0.15rem 0.55rem;border-radius:4px;font-weight:700;font-size:0.8rem;font-family:'Barlow Condensed',sans-serif;">0 pts</span>
              <span style="font-size:0.83rem;color:rgba(255,255,255,0.55);">Resultado errado</span>
            </div>
          </div>
        </div>
      </div>

      <div style="border-top:1px solid rgba(255,255,255,0.08);margin-top:2rem;padding-top:1.5rem;text-align:center;font-size:0.75rem;color:rgba(255,255,255,0.3);">
        © 2026 Polla Mundial · SaludTools · No afiliado con FIFA
      </div>
    </div>
  </footer>

  <!-- Auth state script -->
  <script>
    import { auth, onAuthStateChanged, signOut } from '../lib/firebase';

    const ADMIN_EMAILS = [import.meta.env.PUBLIC_ADMIN_EMAIL].filter(Boolean);

    onAuthStateChanged(auth, (user) => {
      const authDiv = document.getElementById('navbar-auth');
      if (!authDiv) return;
      if (user) {
        if (ADMIN_EMAILS.includes(user.email ?? '')) {
          const adminLink = document.getElementById('nav-admin');
          if (adminLink) adminLink.style.display = '';
        }
        const initial = (user.displayName || user.email || 'U')[0].toUpperCase();
        authDiv.innerHTML = `
          <a href="/mis-predicciones" class="nav-link" style="display:flex;align-items:center;gap:0.5rem;color:var(--color-text-2);">
            <span style="background:var(--color-primary);color:#fff;width:1.9rem;height:1.9rem;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-weight:600;font-size:0.78rem;flex-shrink:0;">${initial}</span>
            <span style="font-size:0.88rem;">${user.displayName?.split(' ')[0] || 'Mi cuenta'}</span>
          </a>
          <button id="btn-logout" class="btn btn-outline-light btn-sm">
            Salir
          </button>
        `;
        document.getElementById('btn-logout')?.addEventListener('click', () => signOut(auth).then(() => { window.location.href = '/'; }));
      }
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
