---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bracket Eliminatorias" activePage="avanza">
  <div class="page-header">
    <div class="container">
      <div class="section-label">Fase eliminatoria</div>
      <h1>Bracket del Mundial 2026</h1>
      <p>Sigue el avance de los equipos desde los Dieciseisavos de Final hasta la Gran Final. Horarios en hora Bogotá (UTC-5).</p>
    </div>
  </div>

  <section style="padding:2rem 0 3rem;">
    <div class="container">
      <div id="bracket-loading" style="text-align:center;padding:4rem 0;">
        <div class="spinner" style="margin:0 auto;"></div>
        <p style="margin-top:1rem;color:var(--color-text-3);">Cargando bracket...</p>
      </div>
      <div id="bracket-error" style="display:none;text-align:center;padding:4rem 0;">
        <div style="font-size:3rem;margin-bottom:1rem;">⚠️</div>
        <h3>No se pudo cargar el bracket</h3>
        <p id="bracket-error-msg" style="margin:0.75rem 0 0.5rem;color:var(--color-text-3);"></p>
        <button onclick="window.location.reload()" class="btn btn-primary" style="margin-top:1rem;">Reintentar</button>
      </div>
    </div>

    <div id="bracket-scroll" style="display:none;overflow-x:auto;padding:0 1rem 1rem;">
      <div class="bracket">

        <!-- R32 Left -->
        <div class="round">
          <div class="round-header">Dieciseisavos</div>
          <div class="round-matches" id="col-r32L"></div>
        </div>

        <!-- R16 Left -->
        <div class="round connector-left">
          <div class="round-header">Octavos</div>
          <div class="round-matches r16" id="col-r16L"></div>
        </div>

        <!-- QF Left -->
        <div class="round connector-left">
          <div class="round-header">Cuartos</div>
          <div class="round-matches qf" id="col-qfL"></div>
        </div>

        <!-- SF Left -->
        <div class="round connector-left">
          <div class="round-header">Semifinal</div>
          <div class="round-matches sf" id="col-sfL"></div>
        </div>

        <!-- FINAL CENTER -->
        <div class="round final-col">
          <div class="round-header" style="color:var(--color-gold);font-size:1rem;">FINAL</div>
          <div class="round-matches final-matches">
            <div id="col-final"></div>
            <div style="margin-top:1.5rem;">
              <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-text-3);font-weight:700;text-align:center;margin-bottom:0.5rem;">3er Puesto</div>
              <div id="col-third"></div>
            </div>
          </div>
        </div>

        <!-- SF Right -->
        <div class="round connector-right">
          <div class="round-header">Semifinal</div>
          <div class="round-matches sf" id="col-sfR"></div>
        </div>

        <!-- QF Right -->
        <div class="round connector-right">
          <div class="round-header">Cuartos</div>
          <div class="round-matches qf" id="col-qfR"></div>
        </div>

        <!-- R16 Right -->
        <div class="round connector-right">
          <div class="round-header">Octavos</div>
          <div class="round-matches r16" id="col-r16R"></div>
        </div>

        <!-- R32 Right -->
        <div class="round">
          <div class="round-header">Dieciseisavos</div>
          <div class="round-matches" id="col-r32R"></div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  import { db, collection, query, orderBy, getDocs } from '../lib/firebase';
  import { getAllGroupStandings } from '../lib/db';
  import { resolveBracket, flagUrl, isPlaceholder, prettyCode } from '../lib/knockout';

  // Qué partidos van en cada columna del cuadro (ids del seed).
  const COLUMNS: Record<string, string[]> = {
    'col-r32L':  ['m073','m074','m075','m076','m077','m078','m079','m080'],
    'col-r32R':  ['m081','m082','m083','m084','m085','m086','m087','m088'],
    'col-r16L':  ['m089','m090','m091','m092'],
    'col-r16R':  ['m093','m094','m095','m096'],
    'col-qfL':   ['m097','m098'],
    'col-qfR':   ['m099','m100'],
    'col-sfL':   ['m101'],
    'col-sfR':   ['m102'],
    'col-final': ['m104'],
    'col-third': ['m103'],
  };

  const fmt = (utc: string) => {
    try {
      return new Date(utc).toLocaleDateString('es-CO', {
        day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
        timeZone: 'America/Bogota',
      });
    } catch { return utc; }
  };

  function teamRow(code: string, score: number | null, win: boolean): string {
    const ph = isPlaceholder(code);
    const name = ph ? prettyCode(code) : code;
    const flag = ph
      ? `<span class="team-flag is-ph"></span>`
      : `<img class="team-flag" src="${flagUrl(code)}" alt="${name}" onerror="this.src='https://flagcdn.com/w40/un.png'">`;
    const sc = score != null ? `<span class="team-score">${score}</span>` : '';
    return `<div class="team-slot${win ? ' winner' : ''}${ph ? ' placeholder' : ''}">${flag}<span class="team-name">${name}</span>${sc}</div>`;
  }

  function slotInner(m: any, resolved: Map<string, { home: string; away: string }>): string {
    const r = resolved.get(m.id) || { home: m.homeTeam, away: m.awayTeam };
    const finished = m.homeScore != null && m.awayScore != null;
    const homeWin = finished && m.homeScore > m.awayScore;
    const awayWin = finished && m.awayScore > m.homeScore;
    const label = m.id === 'm103' ? '3er Puesto' : `P${m.matchNumber}`;
    return `
      <div class="match-meta">${label} · ${fmt(m.utcDateTime)}</div>
      ${teamRow(r.home, finished ? m.homeScore : null, homeWin)}
      ${teamRow(r.away, finished ? m.awayScore : null, awayWin)}
    `;
  }

  async function init() {
    let matches: any[] = [];
    let resolved: Map<string, { home: string; away: string }>;
    try {
      const snap = await getDocs(query(collection(db, 'matches'), orderBy('utcDateTime', 'asc')));
      matches = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      try {
        const gs = await getAllGroupStandings();
        const standings: Record<string, any[]> = {};
        Object.values(gs).forEach((g: any) => { if (g?.group) standings[g.group] = g.teams ?? []; });
        resolved = resolveBracket(matches as any, standings);
      } catch {
        resolved = resolveBracket(matches as any, {});
      }
    } catch (e: any) {
      console.error(e);
      (document.getElementById('bracket-loading') as HTMLElement).style.display = 'none';
      const err = document.getElementById('bracket-error') as HTMLElement;
      (document.getElementById('bracket-error-msg') as HTMLElement).textContent =
        e?.message ?? 'Error al conectar con la base de datos.';
      err.style.display = 'block';
      return;
    }

    const byId = new Map(matches.map(m => [m.id, m]));
    Object.entries(COLUMNS).forEach(([colId, ids]) => {
      const col = document.getElementById(colId);
      if (!col) return;
      col.innerHTML = ids.map(id => {
        const m = byId.get(id);
        if (!m) return '';
        const isFinal = id === 'm104';
        return `<div class="match-slot${isFinal ? ' final-slot' : ''}" data-match="${id}">${slotInner(m, resolved)}</div>`;
      }).join('');
    });

    (document.getElementById('bracket-loading') as HTMLElement).style.display = 'none';
    (document.getElementById('bracket-scroll') as HTMLElement).style.display = 'block';
  }

  init();
</script>

<!-- Estilos globales (namespaceados bajo .bracket) porque los slots se inyectan
     vía innerHTML y no reciben el atributo de scope de Astro. -->
<style is:global>
  .bracket {
    display: flex;
    align-items: center;
    gap: 0;
    min-width: 1400px;
    padding: 1rem 0;
  }

  .bracket .round {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    min-width: 160px;
  }

  .bracket .final-col {
    min-width: 185px;
    flex: 1.2;
  }

  .bracket .round-header {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
    border-bottom: 2px solid var(--color-gold);
    padding-bottom: 0.4rem;
    width: 100%;
  }

  .bracket .round-matches {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    justify-content: space-around;
    align-items: center;
    min-height: 520px;
  }

  .bracket .round-matches.r16 { min-height: 520px; gap: 1rem; }
  .bracket .round-matches.qf  { min-height: 520px; gap: 3rem; }
  .bracket .round-matches.sf  { min-height: 520px; justify-content: center; }
  .bracket .round-matches.final-matches { min-height: 520px; justify-content: center; gap: 1.5rem; }

  .bracket .match-slot {
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 6px;
    padding: 0.45rem 0.55rem;
    width: 158px;
    box-shadow: 0 1px 3px rgba(10,36,114,0.06);
    position: relative;
    box-sizing: border-box;
  }

  .bracket .final-slot {
    border-color: var(--color-gold);
    border-width: 2px;
    box-shadow: 0 2px 12px rgba(255,197,0,0.2);
    width: 172px;
  }

  .bracket .match-meta {
    font-size: 0.6rem;
    color: var(--color-text-3);
    font-weight: 500;
    margin-bottom: 0.4rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bracket .team-slot {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.2rem;
    border-radius: 3px;
  }

  .bracket .team-slot:first-of-type {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.15rem;
  }

  .bracket .team-slot.winner .team-name { color: var(--color-green, #1a7a4a); }
  .bracket .team-slot.winner .team-score { color: var(--color-green, #1a7a4a); }

  .bracket .team-slot.placeholder .team-name {
    color: var(--color-text-3);
    font-style: italic;
    font-weight: 600;
    font-size: 0.7rem;
  }

  .bracket .team-flag {
    width: 20px;
    height: 14px;
    object-fit: cover;
    border-radius: 2px;
    flex-shrink: 0;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
  }

  .bracket .team-flag.is-ph {
    display: inline-block;
    background: var(--color-surface-2);
    border: 1px dashed var(--color-border);
    box-shadow: none;
  }

  .bracket .team-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.76rem;
    line-height: 1.15;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .bracket .team-score {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--color-text);
    flex-shrink: 0;
    min-width: 1ch;
    text-align: right;
  }

  /* Connector lines using pseudo-elements */
  .bracket .connector-left .match-slot::before {
    content: '';
    position: absolute;
    left: -20px;
    top: 50%;
    width: 20px;
    height: 1px;
    background: var(--color-border);
  }

  .bracket .connector-right .match-slot::after {
    content: '';
    position: absolute;
    right: -20px;
    top: 50%;
    width: 20px;
    height: 1px;
    background: var(--color-border);
  }

  @media (max-width: 900px) {
    .bracket { min-width: 1200px; }
  }
</style>
