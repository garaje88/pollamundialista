---
import Layout from '../layouts/Layout.astro';

interface BracketMatch {
  id: string;
  label: string;
  date: string;
  time: string;
  home: string;
  away: string;
}

function utcToLocal(utcStr: string): { date: string; time: string } {
  const d = new Date(utcStr);
  const date = d.toLocaleDateString('es-CO', { timeZone: 'America/Bogota', day: 'numeric', month: 'short' });
  const time = d.toLocaleTimeString('es-CO', { timeZone: 'America/Bogota', hour: '2-digit', minute: '2-digit' });
  return { date, time };
}

const r32L: BracketMatch[] = [
  { id:'M73',  label:'P73',  ...(() => { const {date,time}=utcToLocal('2026-06-28T19:00:00Z'); return {date,time}; })(), home:'2A',     away:'2B'      },
  { id:'M74',  label:'P74',  ...(() => { const {date,time}=utcToLocal('2026-06-29T20:30:00Z'); return {date,time}; })(), home:'1E',     away:'3ABCDF'  },
  { id:'M75',  label:'P75',  ...(() => { const {date,time}=utcToLocal('2026-06-30T01:00:00Z'); return {date,time}; })(), home:'1F',     away:'2C'      },
  { id:'M76',  label:'P76',  ...(() => { const {date,time}=utcToLocal('2026-06-30T21:00:00Z'); return {date,time}; })(), home:'1G',     away:'3ABHIJ'  },
  { id:'M77',  label:'P77',  ...(() => { const {date,time}=utcToLocal('2026-07-01T00:00:00Z'); return {date,time}; })(), home:'1I',     away:'3CDFGH'  },
  { id:'M78',  label:'P78',  ...(() => { const {date,time}=utcToLocal('2026-07-01T19:00:00Z'); return {date,time}; })(), home:'1J',     away:'3EFGKL'  },
  { id:'M79',  label:'P79',  ...(() => { const {date,time}=utcToLocal('2026-07-02T01:00:00Z'); return {date,time}; })(), home:'2G',     away:'2H'      },
  { id:'M80',  label:'P80',  ...(() => { const {date,time}=utcToLocal('2026-07-02T23:00:00Z'); return {date,time}; })(), home:'2I',     away:'2J'      },
];

const r32R: BracketMatch[] = [
  { id:'M81',  label:'P81',  ...(() => { const {date,time}=utcToLocal('2026-06-28T23:00:00Z'); return {date,time}; })(), home:'1A',     away:'3BDEKL'  },
  { id:'M82',  label:'P82',  ...(() => { const {date,time}=utcToLocal('2026-06-29T01:00:00Z'); return {date,time}; })(), home:'2D',     away:'2E'      },
  { id:'M83',  label:'P83',  ...(() => { const {date,time}=utcToLocal('2026-06-29T23:00:00Z'); return {date,time}; })(), home:'2K',     away:'2L'      },
  { id:'M84',  label:'P84',  ...(() => { const {date,time}=utcToLocal('2026-06-30T02:00:00Z'); return {date,time}; })(), home:'1B',     away:'3ACDIJ'  },
  { id:'M85',  label:'P85',  ...(() => { const {date,time}=utcToLocal('2026-07-01T20:00:00Z'); return {date,time}; })(), home:'1H',     away:'3CDFL'   },
  { id:'M86',  label:'P86',  ...(() => { const {date,time}=utcToLocal('2026-07-02T00:00:00Z'); return {date,time}; })(), home:'2F',     away:'1D'      },
  { id:'M87',  label:'P87',  ...(() => { const {date,time}=utcToLocal('2026-07-03T00:00:00Z'); return {date,time}; })(), home:'1C',     away:'3AEGHK'  },
  { id:'M88',  label:'P88',  ...(() => { const {date,time}=utcToLocal('2026-07-03T23:00:00Z'); return {date,time}; })(), home:'2E',     away:'1L'      },
];

const r16L: BracketMatch[] = [
  { id:'M89', label:'P89', ...(() => { const {date,time}=utcToLocal('2026-07-04T21:00:00Z'); return {date,time}; })(), home:'W-P74', away:'W-P77' },
  { id:'M90', label:'P90', ...(() => { const {date,time}=utcToLocal('2026-07-04T17:00:00Z'); return {date,time}; })(), home:'W-P73', away:'W-P75' },
  { id:'M91', label:'P91', ...(() => { const {date,time}=utcToLocal('2026-07-05T21:00:00Z'); return {date,time}; })(), home:'W-P76', away:'W-P79' },
  { id:'M92', label:'P92', ...(() => { const {date,time}=utcToLocal('2026-07-06T00:00:00Z'); return {date,time}; })(), home:'W-P78', away:'W-P80' },
];

