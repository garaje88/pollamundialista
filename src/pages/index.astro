---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

const firstMatchDate = new Date('2026-06-11T14:00:00-05:00');
const now = new Date();
const msLeft = firstMatchDate.getTime() - now.getTime();
const daysLeft = Math.max(0, Math.ceil(msLeft / (1000 * 60 * 60 * 24)));
---

<Layout title="Inicio" activePage="inicio">

  <!-- ═══════════════════════════════════════════
       HERO — 2 columns, light gradient, grid bg
  ════════════════════════════════════════════ -->
  <section class="hero-strip">
    <div class="container" style="position:relative;z-index:1;">
      <div class="hero-grid">

        <!-- Left: content -->
        <div class="hero-content">
          <span class="badge badge-primary" style="margin-bottom:1.25rem;display:inline-flex;">
            ⚽ FIFA World Cup 2026 · 11 Jun — 19 Jul
          </span>

          <h1 style="font-size:clamp(2.6rem,5.5vw,3.8rem);margin-bottom:1rem;color:var(--color-primary);">
            La Polla del<br>
            <span style="color:var(--color-st-red);">Equipo SaludTools</span>
          </h1>

          <p style="font-size:1.05rem;max-width:480px;margin-bottom:2rem;color:var(--color-text-2);line-height:1.65;">
            Predice los marcadores de los 72 partidos de la fase de grupos, compite con tus compañeros y demuestra quién sabe más de fútbol en el equipo.
          </p>

          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.75rem;">
            <a href="/login"    class="btn btn-primary btn-lg" id="hero-cta-btn">Unirme con Google →</a>
            <a href="/partidos" class="btn btn-outline-light btn-lg">Ver partidos</a>
          </div>

          {daysLeft > 0 ? (
            <div class="countdown-pill">
              <span class="countdown-number">{daysLeft}</span>
              <span class="countdown-label">días para el pitazo inicial · 11 Jun · MetLife Stadium</span>
            </div>
          ) : (
            <div class="countdown-pill" style="background:rgba(229,48,64,0.08);border-color:rgba(229,48,64,0.2);">
              <span style="font-size:1rem;">🔴</span>
              <span class="countdown-label" style="color:var(--color-st-red);">El torneo ya comenzó. ¡Predice ahora!</span>
            </div>
          )}
        </div>

        <!-- Right: preview widget -->
        <div class="hero-visual" aria-hidden="true">
          <div class="preview-widget">
            <!-- Header -->
            <div class="preview-widget-header">
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="width:7px;height:7px;border-radius:50%;background:var(--color-st-red);display:inline-block;"></span>
                <span style="font-size:0.75rem;font-weight:600;color:var(--color-text-2);">Grupo C · 25 Jun, 18:00 COT</span>
              </div>
              <span class="badge badge-green" style="font-size:0.65rem;">En curso</span>
            </div>

            <!-- Match -->
            <div class="preview-match">
              <div class="preview-team">
                <img src="https://flagcdn.com/w80/co.png" alt="Colombia" class="preview-flag" />
                <span>Colombia</span>
              </div>
              <div class="preview-score-block">
                <span class="preview-live-score">2</span>
                <span style="color:var(--color-text-3);font-weight:300;font-size:1.4rem;">—</span>
                <span class="preview-live-score">1</span>
              </div>
              <div class="preview-team">
                <img src="https://flagcdn.com/w80/ar.png" alt="Argentina" class="preview-flag" />
                <span>Argentina</span>
              </div>
            </div>

            <!-- Prediction row -->
            <div class="preview-prediction-row">
              <span style="font-size:0.72rem;color:var(--color-text-3);font-weight:500;">Tu predicción</span>
              <div style="display:flex;align-items:center;gap:0.4rem;">
                <span class="preview-input-bubble">2</span>
                <span style="color:var(--color-text-3);font-size:0.9rem;">—</span>
                <span class="preview-input-bubble">1</span>
              </div>
              <span class="badge badge-gold" style="font-size:0.7rem;">+5 pts exacto</span>
            </div>

            <!-- Mini leaderboard -->
            <div class="preview-leaderboard">
              <div style="font-size:0.65rem;font-weight:600;color:var(--color-text-3);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.6rem;">Clasificación del equipo</div>
              <div class="preview-rank-row">
                <span style="font-size:0.85rem;">🥇</span>
                <span class="preview-rank-name">María G.</span>
                <span class="preview-rank-pts">42 pts</span>
              </div>
              <div class="preview-rank-row" style="opacity:0.75;">
                <span style="font-size:0.85rem;">🥈</span>
                <span class="preview-rank-name">Carlos P.</span>
                <span class="preview-rank-pts">38 pts</span>
              </div>
              <div class="preview-rank-row" style="opacity:0.55;">
                <span style="font-size:0.85rem;">🥉</span>
                <span class="preview-rank-name">Andrea M.</span>
                <span class="preview-rank-pts">35 pts</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       STATS BAR
  ════════════════════════════════════════════ -->
  <section style="background:var(--color-surface);border-bottom:1px solid var(--color-border);">
    <div class="container">
      <div class="stats-bar">
        <div class="stat-item">
          <span class="stat-number">48</span>
          <span class="stat-label">Selecciones</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">72</span>
          <span class="stat-label">Partidos fase grupos</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">16</span>
          <span class="stat-label">Estadios</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">39</span>
          <span class="stat-label">Días de torneo</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY JOIN
  ════════════════════════════════════════════ -->
  <section style="padding:4.5rem 0;background:var(--color-bg);">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;">
        <h2>¿Por qué unirte a la polla del equipo?</h2>
        <p style="margin-top:0.6rem;max-width:440px;margin-inline:auto;">Una manera divertida de vivir el Mundial junto al equipo de SaludTools.</p>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🤝</div>
          <h4>Equipo unido</h4>
          <p>Comparte la emoción de cada partido con los compañeros. Celebra los aciertos juntos y aguanta las apuestas perdidas.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🏆</div>
          <h4>Compite por el primer lugar</h4>
          <p>Sube al tope de la tabla y demuéstrale a todos en el equipo que eres el mejor pronosticador del Mundial.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">⚡</div>
          <h4>Dos minutos para empezar</h4>
          <p>Ingresa con tu cuenta de Google, predice los partidos que quieras y listo. Sin instalaciones, sin registros largos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT WORKS
  ════════════════════════════════════════════ -->
  <section style="padding:4.5rem 0;background:var(--color-surface);border-top:1px solid var(--color-border);">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;">
        <h2>Cómo funciona</h2>
      </div>
      <div class="steps-grid">
        <div class="step-item">
          <div class="step-number">1</div>
          <div>
            <h4 style="margin-bottom:0.35rem;">Inicia sesión con Google</h4>
            <p style="font-size:0.88rem;">Usa tu cuenta de Google corporativa de SaludTools o cualquier cuenta Gmail.</p>
          </div>
        </div>
        <div class="step-connector" aria-hidden="true"></div>
        <div class="step-item">
          <div class="step-number">2</div>
          <div>
            <h4 style="margin-bottom:0.35rem;">Predice los marcadores</h4>
            <p style="font-size:0.88rem;">Ingresa tu predicción en cada partido antes del pitido inicial. Hasta el último minuto puedes cambiarla.</p>
          </div>
        </div>
        <div class="step-connector" aria-hidden="true"></div>
        <div class="step-item">
          <div class="step-number">3</div>
          <div>
            <h4 style="margin-bottom:0.35rem;">Acumula puntos y sube</h4>
            <p style="font-size:0.88rem;">Los puntos se calculan automáticamente. Sigue la tabla en tiempo real durante todo el torneo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SCORING SYSTEM
  ════════════════════════════════════════════ -->
  <section style="padding:4.5rem 0;background:var(--color-bg);">
    <div class="container">
      <div style="max-width:500px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:2rem;">
          <h2>Sistema de puntos</h2>
          <p style="margin-top:0.5rem;">Tres niveles de acierto, tres niveles de recompensa.</p>
        </div>
        <div class="scoring-card">
          <div class="scoring-row scoring-row-exact">
            <div class="scoring-badge" style="background:var(--color-gold);color:var(--color-primary-700);">5</div>
            <div>
              <div style="font-weight:700;color:var(--color-text);font-size:0.95rem;">Resultado exacto</div>
              <div style="font-size:0.8rem;color:var(--color-text-3);margin-top:0.1rem;">Predices el marcador completo: 2-1, 0-0, etc.</div>
            </div>
          </div>
          <div class="scoring-row scoring-row-winner">
            <div class="scoring-badge" style="background:var(--color-green);color:#fff;">2</div>
            <div>
              <div style="font-weight:700;color:var(--color-text);font-size:0.95rem;">Ganador correcto</div>
              <div style="font-size:0.8rem;color:var(--color-text-3);margin-top:0.1rem;">Aciertas quién gana o que empatarán.</div>
            </div>
          </div>
          <div class="scoring-row">
            <div class="scoring-badge" style="background:var(--color-border);color:var(--color-text-3);">0</div>
            <div>
              <div style="font-weight:700;color:var(--color-text);font-size:0.95rem;">Sin puntos</div>
              <div style="font-size:0.8rem;color:var(--color-text-3);margin-top:0.1rem;">El resultado va en otra dirección.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA FINAL
  ════════════════════════════════════════════ -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div>
          <h2 style="color:#fff;margin-bottom:0.75rem;">
            ¿Listo para demostrar que sabes de fútbol?
          </h2>
          <p style="color:rgba(255,255,255,0.7);max-width:420px;line-height:1.6;">
            Únete al equipo de SaludTools en la polla del Mundial 2026. El torneo inicia el 11 de junio.
          </p>
        </div>
        <a href="/login" class="btn btn-gold btn-lg" id="cta-join-btn" style="flex-shrink:0;font-size:1rem;">
          Unirme ahora →
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  import { auth, onAuthStateChanged } from '../lib/firebase';
  onAuthStateChanged(auth, (user) => {
    if (!user) return;
    const heroBtn = document.getElementById('hero-cta-btn') as HTMLAnchorElement;
    if (heroBtn) { heroBtn.href = '/mis-predicciones'; heroBtn.textContent = 'Ver mis picks →'; }
    const ctaBtn = document.getElementById('cta-join-btn') as HTMLAnchorElement;
    if (ctaBtn) { ctaBtn.href = '/mis-predicciones'; ctaBtn.textContent = 'Ver mis predicciones →'; }
  });
</script>

<style>
  /* ── Hero ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .countdown-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    background: rgba(48,80,217,0.07);
    border: 1px solid rgba(48,80,217,0.15);
    border-radius: 99px;
    padding: 0.5rem 1rem;
  }
  .countdown-number {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    color: var(--color-primary);
    line-height: 1;
  }
  .countdown-label {
    font-size: 0.78rem;
    color: var(--color-text-2);
    font-weight: 500;
  }

  /* ── Preview widget ── */
  .preview-widget {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(48,80,217,0.14), 0 4px 12px rgba(0,0,0,0.06);
    border: 1px solid rgba(48,80,217,0.1);
    overflow: hidden;
    transform: perspective(800px) rotateY(-4deg) rotateX(2deg);
    transition: transform 0.3s ease;
  }
  .preview-widget:hover {
    transform: perspective(800px) rotateY(-1deg) rotateX(1deg);
  }
  .preview-widget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
  }
  .preview-match {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.4rem;
    gap: 0.5rem;
  }
  .preview-team {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
    min-width: 72px;
    text-align: center;
  }
  .preview-flag {
    width: 44px;
    height: 30px;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }
  .preview-score-block {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .preview-live-score {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.4rem;
    color: var(--color-primary);
    line-height: 1;
  }
  .preview-prediction-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.65rem 1.1rem;
    background: var(--color-surface-2);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .preview-input-bubble {
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 6px;
    background: var(--color-primary-light);
    border: 1.5px solid rgba(48,80,217,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--color-primary);
  }
  .preview-leaderboard {
    padding: 0.85rem 1.1rem;
  }
  .preview-rank-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0;
  }
  .preview-rank-name {
    flex: 1;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .preview-rank-pts {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: 'Barlow Condensed', sans-serif;
  }

  /* ── Stats bar ── */
  .stats-bar {
    display: flex;
    align-items: center;
    padding: 0;
  }
  .stat-item {
    flex: 1;
    padding: 1.4rem 1rem;
    text-align: center;
  }
  .stat-number {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2rem;
    color: var(--color-primary);
    line-height: 1;
  }
  .stat-label {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-3);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-weight: 600;
    margin-top: 0.3rem;
  }
  .stat-divider {
    width: 1px;
    height: 2.5rem;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* ── Why join ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .why-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem 1.5rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .why-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }
  .why-icon {
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
  }
  .why-card h4 {
    margin-bottom: 0.5rem;
    color: var(--color-text);
    font-size: 1rem;
  }
  .why-card p {
    font-size: 0.87rem;
    color: var(--color-text-2);
    line-height: 1.6;
  }

  /* ── How it works ── */
  .steps-grid {
    display: flex;
    align-items: flex-start;
    gap: 0;
    max-width: 820px;
    margin: 0 auto;
  }
  .step-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.85rem;
    padding: 0 1rem;
  }
  .step-number {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .step-connector {
    width: 60px;
    height: 2px;
    background: var(--color-border);
    margin-top: 1.375rem;
    flex-shrink: 0;
  }

  /* ── Scoring ── */
  .scoring-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .scoring-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .scoring-row:last-child { border-bottom: none; }
  .scoring-badge {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  /* ── CTA final ── */
  .cta-section {
    background: var(--color-primary);
    padding: 4rem 0;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-visual { display: none; }
    .why-grid { grid-template-columns: 1fr; }
    .steps-grid { flex-direction: column; align-items: stretch; gap: 1.5rem; }
    .step-connector { display: none; }
    .step-item { flex-direction: row; text-align: left; }
    .cta-inner { flex-direction: column; text-align: center; }
    .cta-inner .btn { width: 100%; justify-content: center; }
  }
  @media (max-width: 640px) {
    .stats-bar { flex-wrap: wrap; }
    .stat-item { min-width: 50%; }
    .stat-divider { display: none; }
  }
</style>
