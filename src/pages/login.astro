---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar sesión">
  <section style="min-height:calc(100vh - 200px);display:flex;align-items:center;padding:3rem 0;background:var(--color-bg);">
    <div class="container" style="max-width:420px;margin:0 auto;">

      <div style="text-align:center;margin-bottom:2rem;">
        <div style="display:inline-flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
          <svg width="44" height="44" viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="15" fill="#FFC500" stroke="#0A2472" stroke-width="1.5"/>
            <path d="M16 3 L19 11 H27 L21 17 L24 25 L16 20 L8 25 L11 17 L5 11 H13 Z" fill="#0A2472"/>
          </svg>
          <span style="font-family:var(--font-display);font-weight:900;font-size:1.8rem;color:var(--color-primary);">
            Mundial<span style="color:var(--color-gold);">2026</span>
          </span>
        </div>
        <h2 style="color:var(--color-primary);margin-bottom:0.5rem;">Bienvenido</h2>
        <p style="color:var(--color-text-2);font-size:0.95rem;">
          Accede con tu cuenta de Gmail para guardar tus predicciones y competir en la tabla.
        </p>
      </div>

      <div class="card" style="padding:2rem;">
        <button id="btn-google" class="btn" style="width:100%;background:#fff;border:2px solid var(--color-border);color:var(--color-text);justify-content:center;padding:0.9rem;font-size:1rem;gap:0.75rem;border-radius:var(--radius-md);">
          <svg width="20" height="20" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continuar con Google
        </button>

        <div id="error-msg" style="display:none;margin-top:1rem;padding:0.75rem 1rem;background:rgba(214,40,57,0.08);border:1px solid rgba(214,40,57,0.25);border-radius:var(--radius-sm);color:var(--color-accent);font-size:0.85rem;text-align:center;"></div>

        <div style="margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--color-border);text-align:center;">
          <div style="display:flex;gap:1.5rem;justify-content:center;font-size:0.8rem;color:var(--color-text-3);">
            <div style="display:flex;align-items:center;gap:0.4rem;">
              <span>🎯</span> 104 partidos
            </div>
            <div style="display:flex;align-items:center;gap:0.4rem;">
              <span>🏆</span> Tabla general
            </div>
            <div style="display:flex;align-items:center;gap:0.4rem;">
              <span>⚽</span> Gratis
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { auth, googleProvider, signInWithPopup } from '../lib/firebase';
  import { createUserProfile, getUserProfile } from '../lib/db';

  document.getElementById('btn-google')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-google') as HTMLButtonElement;
    btn.disabled = true;
    btn.innerHTML = '<div class="spinner" style="width:1.2rem;height:1.2rem;border-width:2px;margin-right:0.5rem;display:inline-block;"></div> Conectando...';

    try {
      const result = await signInWithPopup(auth, googleProvider);
      const user = result.user;
      const existing = await getUserProfile(user.uid);
      if (!existing) {
        await createUserProfile(user.uid, {
          displayName: user.displayName || 'Usuario',
          email: user.email || '',
          photoURL: user.photoURL || undefined,
        });
      }
      window.location.href = '/mis-predicciones';
    } catch (e: any) {
      const errEl = document.getElementById('error-msg')!;
      errEl.textContent = e.code === 'auth/popup-closed-by-user'
        ? 'Ventana cerrada. Inténtalo de nuevo.'
        : 'Error al iniciar sesión con Google. Inténtalo de nuevo.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg> Continuar con Google`;
    }
  });
</script>
