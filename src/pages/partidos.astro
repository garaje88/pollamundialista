---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partidos" activePage="partidos">
  <div class="page-header">
    <div class="container">
      <div class="section-label">Fixture completo</div>
      <h1>Partidos del Mundial 2026</h1>
      <p>Predice el marcador de cada partido antes de que comience. Las predicciones se cierran al pitido inicial.</p>
    </div>
  </div>

  <section style="padding:2.5rem 0;">
    <div class="container">

      <div id="auth-notice" style="display:none;margin-bottom:1.5rem;padding:1rem 1.5rem;background:rgba(255,197,0,0.1);border:1.5px solid var(--color-gold);border-radius:var(--radius-md);">
        <strong>Inicia sesión para guardar tus predicciones.</strong>
        <a href="/login" style="color:var(--color-primary);font-weight:700;margin-left:0.5rem;">Iniciar sesión con Google →</a>
      </div>

      <div class="tabs" id="group-tabs" style="flex-wrap:wrap;margin-bottom:1.5rem;">
        <button class="tab-btn active" data-group="all">Todos</button>
        <button class="tab-btn" data-group="A">Grupo A</button>
        <button class="tab-btn" data-group="B">Grupo B</button>
        <button class="tab-btn" data-group="C">Grupo C</button>
        <button class="tab-btn" data-group="D">Grupo D</button>
        <button class="tab-btn" data-group="E">Grupo E</button>
        <button class="tab-btn" data-group="F">Grupo F</button>
        <button class="tab-btn" data-group="G">Grupo G</button>
        <button class="tab-btn" data-group="H">Grupo H</button>
        <button class="tab-btn" data-group="I">Grupo I</button>
        <button class="tab-btn" data-group="J">Grupo J</button>
        <button class="tab-btn" data-group="K">Grupo K</button>
        <button class="tab-btn" data-group="L">Grupo L</button>
      </div>
      <p style="font-size:0.75rem;color:var(--color-text-3);margin-bottom:1rem;">Horarios en hora de Bogotá (UTC-5)</p>

      <div id="loading-matches" style="text-align:center;padding:4rem 0;">
        <div class="spinner" style="margin:0 auto;"></div>
        <p style="margin-top:1rem;color:var(--color-text-3);">Cargando partidos...</p>
      </div>

      <div id="empty-matches" style="display:none;text-align:center;padding:4rem 0;">
        <div style="font-size:3rem;margin-bottom:1rem;">⚽</div>
        <h3>Los partidos aún no están disponibles</h3>
        <p style="margin:0.75rem 0 0.5rem;">Ejecuta el script de seed para cargar el fixture.</p>
        <code style="background:var(--color-surface-2);padding:0.5rem 1rem;border-radius:var(--radius-sm);font-size:0.85rem;display:inline-block;">npx tsx scripts/seed-matches.ts</code>
      </div>

      <div id="error-matches" style="display:none;text-align:center;padding:4rem 0;">
        <div style="font-size:3rem;margin-bottom:1rem;">⚠️</div>
        <h3>No se pudieron cargar los partidos</h3>
        <p id="error-matches-msg" style="margin:0.75rem 0 0.5rem;color:var(--color-text-3);"></p>
        <p style="font-size:0.85rem;color:var(--color-text-3);margin-top:0.5rem;">
          Si tienes un bloqueador de anuncios activo, intenta deshabilitarlo para este sitio e intenta de nuevo.
        </p>
        <button onclick="window.location.reload()" class="btn btn-primary" style="margin-top:1rem;">Reintentar</button>
      </div>

      <div id="matches-container" style="display:none;flex-direction:column;gap:1rem;"></div>
    </div>
  </section>
</Layout>

<script>
  import { db, collection, query, orderBy, getDocs } from '../lib/firebase';
  import { auth, onAuthStateChanged } from '../lib/firebase';
  import { savePrediction, getUserPredictions } from '../lib/db';

  const FLAG: Record<string, string> = {
    'Mexico':'mx','South Africa':'za','South Korea':'kr','Czech Republic':'cz',
    'Canada':'ca','Bosnia and Herzegovina':'ba','Qatar':'qa','Switzerland':'ch',
    'Brazil':'br','Morocco':'ma','Haiti':'ht','Scotland':'gb-sct',
    'United States':'us','Paraguay':'py','Australia':'au','Turkey':'tr',
    'Germany':'de','Curacao':'cw','Ivory Coast':'ci','Ecuador':'ec',
    'Netherlands':'nl','Japan':'jp','Sweden':'se','Tunisia':'tn',
    'Belgium':'be','Egypt':'eg','Iran':'ir','New Zealand':'nz',
    'Spain':'es','Cape Verde':'cv','Saudi Arabia':'sa','Uruguay':'uy',
    'France':'fr','Senegal':'sn','Iraq':'iq','Norway':'no',
    'Argentina':'ar','Algeria':'dz','Austria':'at','Jordan':'jo',
    'Portugal':'pt','DR Congo':'cd','Uzbekistan':'uz','Colombia':'co',
    'England':'gb-eng','Croatia':'hr','Ghana':'gh','Panama':'pa',
  };

  const flag = (t: string) => `https://flagcdn.com/w80/${FLAG[t] ?? t.slice(0,2).toLowerCase()}.png`;

  const fmtDate = (utc: string) => {
    try {
      return new Date(utc).toLocaleDateString('es-CO', {
        weekday:'short', day:'numeric', month:'short',
        hour:'2-digit', minute:'2-digit', timeZone:'America/Bogota',
      });
    } catch { return utc; }
  };

  let allMatches: any[] = [];
  let user: any = null;
  let preds: Map<string, any> = new Map();
  let group = 'all';

  async function init() {
    onAuthStateChanged(auth, async u => {
      user = u;
      if (!u) {
        (document.getElementById('auth-notice') as HTMLElement).style.display = 'block';
      } else {
        try {
          const list = await getUserPredictions(u.uid);
          preds = new Map(list.map(p => [p.matchId, p]));
        } catch {}
      }
      if (allMatches.length) render();
    });

    try {
      const snap = await getDocs(query(collection(db, 'matches'), orderBy('utcDateTime', 'asc')));
      allMatches = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    } catch (e: any) {
      console.error(e);
      (document.getElementById('loading-matches') as HTMLElement).style.display = 'none';
      const errDiv = document.getElementById('error-matches') as HTMLElement;
      const errMsg = document.getElementById('error-matches-msg') as HTMLElement;
      const isBlocked = e?.message?.includes('Failed to fetch') || e?.code === 'unavailable' || e?.name === 'FirebaseError';
      errMsg.textContent = isBlocked
        ? 'La conexión con la base de datos fue bloqueada o no está disponible.'
        : (e?.message ?? 'Error desconocido al conectar con la base de datos.');
      errDiv.style.display = 'block';
      return;
    }

    (document.getElementById('loading-matches') as HTMLElement).style.display = 'none';

    if (!allMatches.length) {
      (document.getElementById('empty-matches') as HTMLElement).style.display = 'block';
      return;
    }
    render();
    setupTabs();
  }

  function render() {
    const box = document.getElementById('matches-container') as HTMLElement;
    box.style.display = 'flex';
    box.innerHTML = '';

    const list = group === 'all' ? allMatches : allMatches.filter(m => m.group === group);
    if (!list.length) {
      box.innerHTML = '<p style="text-align:center;padding:2rem;color:var(--color-text-3);">No hay partidos.</p>';
      return;
    }

    const rounds: Record<string, any[]> = {};
    list.forEach(m => { (rounds[m.round] ??= []).push(m); });

    Object.entries(rounds).forEach(([rnd, ms]) => {
      const hdr = document.createElement('div');
      hdr.innerHTML = `<div class="section-label" style="padding-top:0.5rem;">${rnd}</div>`;
      box.appendChild(hdr);

      ms.forEach(m => {
        const p = preds.get(m.id);
        const scored = m.homeScore !== null && m.awayScore !== null;

        // Cierre de predicciones: 1 hora antes del pitazo
        const msToKickoff = new Date(m.utcDateTime).getTime() - Date.now();
        const closingSoon = m.status === 'scheduled' && msToKickoff < 60 * 60 * 1000;
        const minsLeft = Math.ceil(msToKickoff / 60000);

        // Construir la fila de predicción antes del innerHTML para evitar literales anidados
        let predRowHtml = '';
        if (m.status === 'scheduled') {
          if (closingSoon) {
            const lockLabel = minsLeft > 0 ? `Cierra en ${minsLeft} min` : 'Por iniciar';
            const predDisplay = p
              ? `<span style="font-family:var(--font-display);font-weight:800;font-size:1.35rem;color:var(--color-text-2);">${p.homeGoals} — ${p.awayGoals}</span>`
              : `<span style="font-size:0.78rem;color:var(--color-text-3);">Sin predicción registrada</span>`;
            predRowHtml = `
<div class="prediction-row" style="background:var(--color-surface-2);">
  <span style="font-size:0.78rem;font-weight:500;color:var(--color-text-3);">Tu predicción:</span>
  ${predDisplay}
  <span style="margin-left:auto;display:flex;align-items:center;gap:0.4rem;">
    <span style="font-size:0.85rem;">🔒</span>
    <span style="font-size:0.75rem;font-weight:600;color:var(--color-text-2);">${lockLabel}</span>
  </span>
</div>`;
          } else {
            predRowHtml = `
<div class="prediction-row">
  <span style="font-size:0.8rem;font-weight:600;color:var(--color-text-3);">Tu predicción:</span>
  <input type="number" min="0" max="20" step="1" placeholder="0" class="input-score" id="h-${m.id}" value="${p ? p.homeGoals : ''}">
  <span style="font-family:var(--font-display);font-weight:700;font-size:1.3rem;color:var(--color-text-3);">-</span>
  <input type="number" min="0" max="20" step="1" placeholder="0" class="input-score" id="a-${m.id}" value="${p ? p.awayGoals : ''}">
  <button class="btn btn-primary btn-sm" id="s-${m.id}">${p ? 'Actualizar' : 'Guardar'}</button>
  <span id="ok-${m.id}" ${p ? '' : 'style="display:none"'}><span class="badge badge-green">✓</span></span>
</div>`;
          }
        }

        const el = document.createElement('div');
        el.className = 'card';
        el.innerHTML = `
<div class="match-card">
  <div class="match-team">
    <img src="${flag(m.homeTeam)}" alt="${m.homeTeam}" class="match-flag" onerror="this.src='https://flagcdn.com/w80/un.png'">
    <span class="match-team-name">${m.homeTeam}</span>
  </div>
  <div class="match-center">
    ${scored ? `<div class="match-score">${m.homeScore} - ${m.awayScore}</div>` : `<div style="font-family:var(--font-display);font-weight:700;font-size:1.1rem;color:var(--color-text-3);">VS</div>`}
    <div class="match-time">${fmtDate(m.utcDateTime)}</div>
    <div class="match-venue">📍 ${m.venue}, ${m.city}</div>
  </div>
  <div class="match-team">
    <img src="${flag(m.awayTeam)}" alt="${m.awayTeam}" class="match-flag" onerror="this.src='https://flagcdn.com/w80/un.png'">
    <span class="match-team-name">${m.awayTeam}</span>
  </div>
</div>
${predRowHtml}`;
        box.appendChild(el);
        if (m.status === 'scheduled' && !closingSoon) {
          document.getElementById(`s-${m.id}`)?.addEventListener('click', () => save(m.id));
        }
      });
    });
  }

  async function save(id: string) {
    if (!user) { window.location.href = '/login'; return; }
    const btn = document.getElementById(`s-${id}`) as HTMLButtonElement;
    const hv = (document.getElementById(`h-${id}`) as HTMLInputElement)?.valueAsNumber;
    const av = (document.getElementById(`a-${id}`) as HTMLInputElement)?.valueAsNumber;
    if (isNaN(hv) || isNaN(av) || hv < 0 || av < 0 || !Number.isInteger(hv) || !Number.isInteger(av)) {
      alert('Ingresa el marcador para ambos equipos. El mínimo permitido es 0.'); return;
    }
    btn.disabled = true; btn.textContent = '...';
    try {
      await savePrediction({ userId: user.uid, matchId: id, homeGoals: hv, awayGoals: av, status: 'pending', createdAt: null, updatedAt: null });
      preds.set(id, { matchId: id, homeGoals: hv, awayGoals: av });
      (document.getElementById(`ok-${id}`) as HTMLElement).style.display = '';
      btn.textContent = '✓ Guardado';
      setTimeout(() => { btn.textContent = 'Actualizar'; btn.disabled = false; }, 1800);
    } catch (e) {
      console.error(e); btn.textContent = 'Error'; btn.disabled = false;
    }
  }

  function setupTabs() {
    document.querySelectorAll('#group-tabs .tab-btn').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('#group-tabs .tab-btn').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        group = (b as HTMLElement).dataset.group ?? 'all';
        render();
      });
    });
  }

  init();
</script>
